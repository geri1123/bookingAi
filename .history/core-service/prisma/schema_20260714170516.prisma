generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid())

  username  String @unique
  firstName String @map("first_name")
  lastName  String @map("last_name")
  email     String @unique

  password String

  status UserStatus @default(PENDING_VERIFICATION)

  emailVerifiedAt DateTime? @map("email_verified_at")

  lastLoginAt DateTime? @map("last_login_at")

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  businessMembers BusinessMember[]
verificationTokens VerificationToken[] 
  invites Invite[]

  @@index([status], map: "idx_users_status")
  @@index([createdAt], map: "idx_users_created_at")
  @@index([lastLoginAt], map: "idx_users_last_login")
  @@map("users")
}
model VerificationToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  type      TokenType
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_verification_tokens_user_id")
  @@index([token], map: "idx_verification_tokens_token")
   @@index([expiresAt], map: "idx_verification_tokens_expires_at")
  @@index([userId, type], map: "idx_verification_tokens_user_type")
  @@map("verification_tokens")
}
model Business {
  id String @id @default(uuid())

  name String

  type BusinessType

  phone String? @unique

  email String? @unique

  address String?

  language BusinessLanguage

  status BusinessStatus @default(PENDING_SETUP)

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")

  members BusinessMember[]

  services Service[]

  resources Resource[]

  employees Employee[]

  customers Customer[]

  reservations Reservation[]

  invites Invite[]

  @@index([type], map: "idx_businesses_type")
  @@index([status], map: "idx_businesses_status")
  @@index([createdAt], map: "idx_businesses_created_at")
  @@index([type, status], map: "idx_businesses_type_status")
  @@map("businesses")
}

model BusinessMember {
  id String @id @default(uuid())

  userId String @map("user_id")

  businessId String @map("business_id")

  role BusinessMemberRole

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId], map: "idx_business_members_user_business_unique")
  @@index([userId], map: "idx_business_members_user_id")
  @@index([businessId], map: "idx_business_members_business_id")
  @@map("business_members")
}

model Service {
  id String @id @default(uuid())

  businessId String @map("business_id")

  name String

  description String?

  duration Int

  price Decimal

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  reservations Reservation[]

  @@index([businessId], map: "idx_services_business_id")
  @@map("services")
}

model Resource {
  id String @id @default(uuid())

  businessId String @map("business_id")

  name String

  type ResourceType

  capacity Int

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  reservations Reservation[]

  @@index([businessId], map: "idx_resources_business_id")
  @@index([type], map: "idx_resources_type")
  @@map("resources")
}

model Employee {
  id String @id @default(uuid())

  businessId String @map("business_id")

  name String

  phone String?

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  schedules Schedule[]

  reservations Reservation[]

  @@index([businessId], map: "idx_employees_business_id")
  @@map("employees")
}

model Schedule {
  id String @id @default(uuid())

  employeeId String @map("employee_id")

  day Int

  startTime String @map("start_time")

  endTime String @map("end_time")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId], map: "idx_schedules_employee_id")
  @@map("schedules")
}

model Customer {
  id String @id @default(uuid())

  businessId String @map("business_id")

  name String

  phone String

  email String?

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  reservations Reservation[]

  @@unique([businessId, phone], map: "idx_customers_business_phone_unique")
  @@index([businessId], map: "idx_customers_business_id")
  @@index([phone], map: "idx_customers_phone")
  @@map("customers")
}

model Reservation {
  id String @id @default(uuid())

  businessId String @map("business_id")

  customerId String @map("customer_id")

  serviceId String @map("service_id")

  resourceId String? @map("resource_id")

  employeeId String? @map("employee_id")

  startTime DateTime @map("start_time")

  endTime DateTime @map("end_time")

  status ReservationStatus

  createdAt DateTime @default(now()) @map("created_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  customer Customer @relation(fields: [customerId], references: [id])

  service Service @relation(fields: [serviceId], references: [id])

  resource Resource? @relation(fields: [resourceId], references: [id])

  employee Employee? @relation(fields: [employeeId], references: [id])

  @@index([businessId], map: "idx_reservations_business_id")
  @@index([customerId], map: "idx_reservations_customer_id")
  @@index([startTime], map: "idx_reservations_start_time")
  @@index([status], map: "idx_reservations_status")
  @@index([businessId, startTime], map: "idx_reservations_business_start_time")
  @@map("reservations")
}

model Invite {
  id String @id @default(uuid())

  businessId String @map("business_id")

  email String

  role BusinessMemberRole

  token String @unique

  status InviteStatus @default(PENDING)

  invitedBy String @map("invited_by")

  expiresAt DateTime @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  inviter User @relation(fields: [invitedBy], references: [id])

  @@index([businessId], map: "idx_invites_business_id")
  @@index([email], map: "idx_invites_email")
  @@map("invites")
}
model KafkaEvent {
  id String @id @default(uuid())

  eventType String @map("event_type")

  aggregateId String @map("aggregate_id")

  payload Json

  status OutboxStatus @default(PENDING)

  retryCount Int @default(0) @map("retry_count")

  publishedAt DateTime? @map("published_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([status], map: "idx_kafka_events_status")
  @@index([status, createdAt], map: "idx_kafka_events_status_created_at")
  @@map("kafka_events")
}
enum UserStatus {
  ACTIVE

  SUSPENDED

  PENDING_VERIFICATION

  DELETED

  @@map("user_status")
}

enum BusinessType {
  RESTAURANT
  DENTIST
  CLINIC
  HOTEL
  SALON
  BARBERSHOP
  SPA
  GYM
  BEAUTY_CLINIC
  VETERINARY
  CAR_WASH
  OTHER

  @@map("business_type")
}

enum BusinessLanguage {
  AL
  EN
  IT

  @@map("business_language")
}

enum BusinessStatus {
  ACTIVE
  PENDING_SETUP
  SUSPENDED
  CLOSED

  @@map("business_status")
}

enum BusinessMemberRole {
  OWNER
  MANAGER
  STAFF

  @@map("business_member_role")
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW

  @@map("reservation_status")
}

enum ResourceType {
  TABLE
  ROOM
  CHAIR
  OTHER

  @@map("resource_type")
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED

  @@map("invite_status")
}
enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  EMAIL_CHANGE

  @@map("token_type")
}

enum OutboxStatus {
  PENDING
  PROCESSING
  PUBLISHED
  FAILED

  @@map("outbox_status")
}